{
  "name": "ngx-theme-manager",
  "private": false,
  "version": "0.0.0",
  "description": "Angular component to switch between different theming stylesheets",
  "keywords": [
    "angular",
    "theme",
    "theme-manager",
    "ngx-theme-manager"
  ],
  "license": "MIT",
  "author": "Markus Windhager <rb-mwindh@altmails.com>",
  "maintainers": [
    {
      "name": "Markus Windhager",
      "email": "rb-mwindh@altmails.com"
    }
  ],
  "contributors": [],
  "homepage": "https://rb-mwindh.github.io/ngx-theme-manager",
  "bugs": {
    "url": "https://github.com/rb-mwindh/ngx-theme-manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rb-mwindh/ngx-theme-manager.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0"
  },
  "lint-staged": {
    "projects/**/*.ts": [
      "npx --no -- eslint --fix"
    ],
    "*": [
      "npx --no -- prettier --write --ignore-unknown"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "scripts": {
    "init": "npm install",
    "commit": "git-cz",
    "typecheck": "run-s typecheck:*",
    "lint": "run-s lint:lib lint:app",
    "test": "run-s test:lib test:app",
    "build": "run-s \"build:lib -- {1}\" \"build:app -- {1}\"",
    "start": "ng serve demo",
    "----------------------": "",
    "lint:lib": "ng lint ngx-theme-manager",
    "lint:app": "ng lint demo",
    "test:lib": "ng test ngx-theme-manager",
    "test:app": "ng test demo",
    "build:lib": "ng build ngx-theme-manager",
    "build:app": "ng build demo",
    "prebuild": "run-s prebuild:*",
    "prebuild:clean": "rimraf dist",
    "preinit": "rimraf node_modules",
    "postinit": "run-s postinit:*",
    "postinit:setup-husky": "husky install",
    "postbuild": "run-s postbuild:*",
    "postbuild:update-package-json": "tsx tools/update-package-json/to-dist.ts",
    "postbuild:update-bom": "tsx tools/update-oss-bom",
    "postbuild:copy-repo-docs": "npx -y copyfiles *.md LICENSE* dist/ngx-theme-manager",
    "postversion": "tsx tools/update-package-json/to-project.ts",
    "typecheck:demo_app": "tsc --noEmit -p projects/demo/tsconfig.app.json",
    "typecheck:demo_eslint": "tsc --noEmit -p projects/demo/tsconfig.eslint.json",
    "typecheck:demo_spec": "tsc --noEmit -p projects/demo/tsconfig.spec.json",
    "typecheck:ngx-theme-manager_lib": "tsc --noEmit -p projects/ngx-theme-manager/tsconfig.lib.json",
    "typecheck:ngx-theme-manager_lib-prod": "tsc --noEmit -p projects/ngx-theme-manager/tsconfig.lib.prod.json",
    "typecheck:ngx-theme-manager_eslint": "tsc --noEmit -p projects/ngx-theme-manager/tsconfig.eslint.json",
    "typecheck:ngx-theme-manager_spec": "tsc --noEmit -p projects/ngx-theme-manager/tsconfig.spec.json"
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "material-icons": "^1.13.14",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.4",
    "@angular/build": "^21.2.18",
    "@angular/cli": "^21.2.18",
    "@angular/compiler-cli": "^21.2.17",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/license-checker": "^25.0.6",
    "@types/node": "^20.19.43",
    "angular-eslint": "19.8.1",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-marbles": "^3.1.1",
    "jest-preset-angular": "^17.0.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.5.2",
    "ng-packagr": "^21.2.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "rimraf": "^5.0.10",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.60.1"
  },
  "overrides": {
    "sockjs": {
      "uuid": "11.1.1"
    }
  }
}
